<IfModule mod_headers.c>
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "no-cache, must-revalidate"
    </FilesMatch>
</IfModule>

RewriteEngine On

# Redirecionamento 301 de index ou index.php para a raiz (evita conteúdo duplicado)
RewriteCond %{REQUEST_URI} !/admin [NC]
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s/+(.*)index(\.php)?[\s?] [NC]
RewriteRule ^(.*)index(\.php)?$ ./ [R=301,L]

# 0. Redireciona qualquer URL que termine em /admin (que não seja a pasta física) para o painel administrativo
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} /admin/?$ [NC]
RewriteRule ^(.*)admin/?$ admin/ [R=301,L]

# 1. Redirecionamento 301 de URLs legadas de artigo.php?slug= para /slug
# Detecta dinamicamente a pasta/subdiretório atual se houver
RewriteCond %{THE_REQUEST} \s/+(.+/)?artigo\.php\?slug=([a-zA-Z0-9\-]+)\s [NC]
RewriteRule ^ /%1%2? [R=301,L]

# 2. Redirecionamento 301 de URLs legadas de produto-detalhe.php?slug= para produto/slug
RewriteCond %{THE_REQUEST} \s/+(.+/)?produto-detalhe\.php\?slug=([a-zA-Z0-9\-]+)\s [NC]
RewriteRule ^ /%1produto/%2? [R=301,L]

# 3. Redireciona acessos diretos de arquivos .php externos (ex: sobre.php -> sobre)
# Ignora a pasta admin e subdiretórios
RewriteCond %{REQUEST_URI} !/admin [NC]
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s/+(.+)\.php[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# 4. Redirecionamento 301 de /blog/slug para /slug (para links antigos)
RewriteCond %{REQUEST_URI} ^/(.+/)?blog/([a-zA-Z0-9\-]+)/?$ [NC]
RewriteRule ^(.+/)?blog/([a-zA-Z0-9\-]+)/?$ /%1%2 [R=301,L]

# 5. Regra interna para carregar blog.php quando acessar /blog
RewriteRule ^blog/?$ blog.php [L,QSA]

# 6. Regra interna para carregar artigo.php com parâmetro slug ao acessar /slug
# Ignora arquivos físicos, diretórios existentes, arquivos PHP existentes e a pasta admin
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php !-f
RewriteCond %{REQUEST_URI} !/admin [NC]
RewriteRule ^([a-zA-Z0-9\-]+)/?$ artigo.php?slug=$1 [L,QSA]


# 7. Regra interna para carregar produto-detalhe.php com parâmetro slug ao acessar /produto/slug
RewriteRule ^produto/([a-zA-Z0-9\-]+)/?$ produto-detalhe.php?slug=$1 [L,QSA]

# 7. Regra interna para servir arquivos PHP sem a extensão na URL
# Ignora a pasta admin
RewriteCond %{REQUEST_URI} !/admin [NC]
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^([^\.]+)/?$ $1.php [L,QSA]
